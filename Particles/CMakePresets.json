{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install",
        "PARTICLES_BUILD_HDF5": "AUTO",
        "PARTICLES_NATIVE_ARCH": "OFF",
        "PARTICLES_FAST_MATH_CUDA": "OFF"
      }
    },
    {
      "name": "generic-x86-nogpu",
      "inherits": "base",
      "displayName": "Generic x86, serial baseline",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PARTICLES_BUILD_OPENMP": "AUTO",
        "PARTICLES_BUILD_CUDA": "OFF"
      }
    },
    {
      "name": "generic-x86-nvidia",
      "inherits": "base",
      "displayName": "Generic x86 with NVIDIA GPU",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PARTICLES_BUILD_OPENMP": "AUTO",
        "PARTICLES_BUILD_CUDA": "AUTO"
      }
    },
    {
      "name": "macos-arm64",
      "inherits": "base",
      "displayName": "macOS Apple Silicon, serial + optional OpenMP + optional HDF5",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PARTICLES_BUILD_HDF5": "AUTO",
        "PARTICLES_BUILD_OPENMP": "AUTO",
        "PARTICLES_BUILD_CUDA": "OFF",
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      }
    },
    {
      "name": "leonardo-a100",
      "inherits": "base",
      "displayName": "Leonardo A100, OpenMP + CUDA + HDF5",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PARTICLES_BUILD_HDF5": "AUTO",
        "PARTICLES_BUILD_OPENMP": "AUTO",
        "PARTICLES_BUILD_CUDA": "AUTO",
        "PARTICLES_CUDA_ARCHITECTURES": "80"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "generic-x86-nogpu",
      "configurePreset": "generic-x86-nogpu"
    },
    {
      "name": "generic-x86-nvidia",
      "configurePreset": "generic-x86-nvidia"
    },
    {
      "name": "macos-arm64",
      "configurePreset": "macos-arm64"
    },
    {
      "name": "leonardo-a100",
      "configurePreset": "leonardo-a100"
    }
  ]
}
